<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Metode Pembayaran QRIS</title>
    <style>
        body { text-align: center; font-family: Arial, sans-serif; padding: 50px; }
        .qris-container { border: 2px solid #ccc; padding: 20px; display: inline-block; border-radius: 10px; }
        img { max-width: 300px; height: auto; }
    </style>
</head>
<body>

    <h2>Silahkan Scan untuk Pembayaran</h2>
    <div class="qris-container">
        <img src="qrisallpayment.png" alt="QRIS Pembayaran">
        <p><strong>Yuk Bayar Menggunakan E-Wallet / M-Banking</strong></p>
    </div>

</body>
</html>
